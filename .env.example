# ============================================================
# Selena's Insurance — Environment Variables
# ------------------------------------------------------------
# SETUP: Copy this file to .env.local and fill in real values
#   cp .env.example .env.local
#
# VERCEL: Add all REQUIRED vars in Project → Settings → Environment Variables
# ============================================================


# ── SUPABASE (REQUIRED) ──────────────────────────────────────
# Get from: supabase.com → Your Project → Settings → API
# Without these, the lead form will return 500 errors
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...


# ── ADMIN PANEL (REQUIRED) ───────────────────────────────────
# Protects the /admin route. Use a strong random string.
# Generate one: openssl rand -base64 32
ADMIN_SECRET_KEY=change-this-to-a-strong-random-secret


# ── BUSINESS INFO (REQUIRED for production) ──────────────────
# These power the phone links, WhatsApp, address, and SEO schema
# If not set, fallback hardcoded values in src/lib/utils.ts are used

# Phone number displayed on the site (format: (951) 555-1234)
NEXT_PUBLIC_BUSINESS_PHONE=(951) 000-0000

# WhatsApp number WITHOUT + or spaces (e.g. 19515551234)
NEXT_PUBLIC_BUSINESS_WHATSAPP=19510000000

# Full street address (e.g. 123 Main St, Moreno Valley, CA 92551)
NEXT_PUBLIC_BUSINESS_ADDRESS=1234 Main St, Moreno Valley, CA 92551

# Business hours shown in header and footer
NEXT_PUBLIC_BUSINESS_HOURS=Lun–Vie 9am–6pm · Sáb 9am–3pm

# Contact email
NEXT_PUBLIC_BUSINESS_EMAIL=info@selenasinsurance.com

# Full Google Maps URL for the business location
NEXT_PUBLIC_BUSINESS_MAPS_URL=https://maps.google.com/?q=Selenas+Insurance+Moreno+Valley+CA


# ── GOOGLE MAPS / LOCAL SEO (OPTIONAL but recommended) ───────
# GPS coordinates for the Local Business JSON-LD schema
# Find yours: maps.google.com → right-click your address → copy coordinates
NEXT_PUBLIC_BUSINESS_LAT=33.9425
NEXT_PUBLIC_BUSINESS_LNG=-117.2297


# ── TWILIO SMS (OPTIONAL) ────────────────────────────────────
# If not set, SMS is silently skipped. Leads still save to Supabase.
# Get from: console.twilio.com
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio phone number (with country code: +19510000000)
TWILIO_PHONE_NUMBER=+19510000000

# Owner's mobile to receive new lead alerts (with country code: +19515551234)
BUSINESS_OWNER_PHONE=+19510000000
